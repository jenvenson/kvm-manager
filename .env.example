# ── Authentication (required) ─────────────────────────────────────────────────
# Admin password — the backend refuses to start if this is unset.
KVM_ADMIN_PASSWORD=change-me-to-a-strong-password
# Admin username (optional, defaults to "admin")
KVM_ADMIN_USER=admin
# Token signing secret. If unset, a random one is generated at startup and all
# sessions are invalidated on restart. Set a stable value in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
KVM_AUTH_SECRET=
# Session/token lifetime in hours (optional, default 168 = 7 days)
KVM_TOKEN_TTL_HOURS=168

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Leave empty for same-origin deployments.
CORS_ORIGINS=

# ── noVNC console (see docker-compose.yml) ────────────────────────────────────
NOVNC_HOST=
NOVNC_PORT=80
NOVNC_PATH=kvm/novnc

# ── Host libvirt group ────────────────────────────────────────────────────────
# GID of the host's "libvirt" group, so the container can reach the socket.
# Find it with: getent group libvirt | cut -d: -f3   (quickstart.sh sets this)
LIBVIRT_GID=
